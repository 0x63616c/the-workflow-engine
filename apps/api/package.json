{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./trpc": "./src/trpc/routers/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@slack/bolt": "^4.7.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.40.0",
    "inngest": "^3.0.0",
    "openai": "^6.34.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

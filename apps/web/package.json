    "@repo/api": "workspace:*",
    "@repo/shared": "workspace:*",
    "@tanstack/react-query": "^5.75.0",
    "@tanstack/react-router": "^1.112.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.0",
    "geist": "^1.3.0",
    "lucide-react": "^0.475.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.0"

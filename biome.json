{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "*.gen.ts",
      ".inngest",
      ".tilt",
      "coverage",
      ".claude/settings.json",
      ".claude/settings.local.json",
      ".claude/skills/brainstorming",
      ".claude/skills/writing-skills",
      ".claude/skills/systematic-debugging"
    ]
  }
}

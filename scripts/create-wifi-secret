#!/usr/bin/env bash
set -euo pipefail

VAULT="Homelab"
ITEM_NAME="WiFi Guest Credentials"

echo "Creating WiFi credentials in 1Password (vault: $VAULT)"
echo ""

read -rp "SSID: " ssid
read -rsp "Password: " password
echo ""

op item create \
  --vault "$VAULT" \
  --category "Login" \
  --title "$ITEM_NAME" \
  "ssid=$ssid" \
  "password=$password"

echo ""
echo "Created: op://$VAULT/$ITEM_NAME"
echo ""
echo "Reference paths:"
echo "  SSID:     op://$VAULT/$ITEM_NAME/ssid"
echo "  Password: op://$VAULT/$ITEM_NAME/password"
echo ""
echo "Next steps:"
echo "  1. Add GitHub secrets (or use op in CI):"
echo "     gh secret set WIFI_SSID --body \"\$(op read 'op://$VAULT/$ITEM_NAME/ssid')\""
echo "     gh secret set WIFI_PASSWORD --body \"\$(op read 'op://$VAULT/$ITEM_NAME/password')\""
echo "  2. Vite exposes them as VITE_WIFI_SSID and VITE_WIFI_PASSWORD"

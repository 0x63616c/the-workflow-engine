#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: scripts/save-tesla-credentials <client-id> <client-secret>"
  exit 1
fi

CLIENT_ID="$1"
CLIENT_SECRET="$2"

op item create \
  --vault Homelab \
  --category "API Credential" \
  --title "Tesla Fleet API" \
  "client-id=$CLIENT_ID" \
  "client-secret=$CLIENT_SECRET"

echo "Saved to 1Password: op://Homelab/Tesla Fleet API"

#!/bin/bash
# Local deploy script — fetches secrets from 1Password then runs kamal deploy.
#
# Use this when deploying from your local machine.
# CI deploys directly via `kamal deploy` with secrets injected as env vars by GitHub Actions.
#
# Usage: scripts/deploy [kamal options]
#   e.g. scripts/deploy
#        scripts/deploy --skip-push

set -e

echo "Fetching secrets from 1Password..."
export KAMAL_REGISTRY_PASSWORD=$(op read "op://Homelab/GitHub Personal Access Token/token")
export HA_TOKEN=$(op read "op://Homelab/Home Assistant Token/credential")
export POSTGRES_PASSWORD=$(op read "op://Homelab/Evee Postgres/password")
export DATABASE_URL="postgresql://evee:${POSTGRES_PASSWORD}@localhost:5432/evee"

echo "Deploying..."
kamal deploy "$@"
